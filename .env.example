# ============================================
# Configurações do Crypto Tracker Telegram
# ============================================

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# WebDriver Configuration
# Opções: chrome, firefox
WEBDRIVER_BROWSER=chrome
WEBDRIVER_HEADLESS=true

# CoinGecko Configuration
COINGECKO_URL=https://www.coingecko.com/pt
COINGECKO_API=https://api.coingecko.com/api/v3

# Scraping Configuration
MAX_CRYPTOS=10
PAGE_LOAD_TIMEOUT=30
ELEMENT_WAIT_TIMEOUT=10
SCROLL_DELAY=2

# Database Configuration
DATABASE_PATH=data/crypto_data.db
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_INTERVAL_HOURS=24

# Alert Configuration
ALERT_ENABLED=true
ALERT_THRESHOLD_PERCENT=5.0
ALERT_CHECK_INTERVAL_HOURS=1

# Chart Configuration
CHART_ENABLED=true
CHART_GENERATION_INTERVAL_HOURS=6
CHART_WIDTH=12
CHART_HEIGHT=6
CHART_DPI=100

# Schedule Configuration
DATA_COLLECTION_INTERVAL_HOURS=2
CHART_GENERATION_INTERVAL_HOURS=6
ALERT_CHECK_INTERVAL_HOURS=1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/crypto_tracker.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Output Configuration
OUTPUT_DIR=data
CHART_OUTPUT_DIR=data/charts
BACKUP_DIR=data/backups

# Proxy Configuration (opcional)
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# User Agent Configuration
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Rate Limiting Configuration
REQUEST_DELAY_SECONDS=2
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Notification Configuration
NOTIFICATION_ENABLED=true
NOTIFICATION_FORMAT=markdown
NOTIFICATION_PARSE_MODE=MarkdownV2
